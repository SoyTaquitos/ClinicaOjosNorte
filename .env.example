# ============================================
# Oftalmología SI1 — Clínica de Ojos Norte
# Variables de Entorno (PLANTILLA)
# ============================================
# Copia este archivo a .env y configura tus valores:
#   cp .env.example .env

# ---- General ----
COMPOSE_PROJECT_NAME=oftalmologia-si1

# ---- PostgreSQL ----
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django Backend ----
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
# Incluye "backend" si el frontend en Docker hace proxy al API por nombre de servicio.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (tiempos en minutos/días)
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# ---- Email (Mailhog en Docker dev | SMTP real en producción) ----
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@clinicaojnorte.local
FRONTEND_URL=http://localhost:3000
# Código numérico enviado por correo (MailHog/SMTP). Mínimo 10 s, máximo 3600 s. Por defecto 180 = 3 min.
PASSWORD_RESET_CODE_TTL_SECONDS=180
# Dígitos del código (entre 4 y 12).
PASSWORD_RESET_CODE_LENGTH=6

# ---- Next.js Frontend (obligatorias en .env cuando usas docker-compose) ----
# Navegador → API. Local: localhost. Desde otra máquina hacia Azure: http://IP_O_DNS_PUBLICO:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Contenedor Next → API (red Docker; el servicio se llama como en compose.yml).
INTERNAL_API_URL=http://backend:8000/api
# Marca y metadatos (sin valores por defecto en código: definir aquí).
NEXT_PUBLIC_APP_NAME=Clínica de Ojos Norte
# Opcional: subtítulo en login / pie de marca.
NEXT_PUBLIC_APP_TAGLINE=Sistema de gestión oftalmológica
# Opcional: descripción para <meta name="description">.
NEXT_PUBLIC_APP_DESCRIPTION=Portal de gestión interna para el personal de la clínica.
# Opcional: palabras clave separadas por comas para <meta name="keywords">.
NEXT_PUBLIC_META_KEYWORDS=oftalmología,clínica,gestión,pacientes,citas

# Login: mostrar credenciales de prueba bajo el formulario (por defecto solo en `next dev`).
# En build de producción no activar salvo demo controlada.
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=true
# NEXT_PUBLIC_DEV_ADMIN_USER=admin
# NEXT_PUBLIC_DEV_ADMIN_PASSWORD=admin123
